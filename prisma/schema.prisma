// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["users", "auth", "academic_profile", "subject", "quizz"]
}

model User {
  id            String    @id @default(uuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  studentCode   String    @unique @map("student_code")
  career        String
  email         String    @unique
  password      String
  avatarUrl     String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLogin     DateTime?

  roleId String
  role   Roles  @relation(fields: [roleId], references: [id])

  academicProfile  AcademicProfile[]
  subjectUser      UserSubject[]
  quizzies         Quizzies[]
  quizziesAttempts QuizAttempts[]

  createdAt       DateTime @default(now())
  updateAt        DateTime @updatedAt
  deletedAt       DateTime?
  grades          Grades[]
  studySessions   StudySessions[]
  recommendations Recommendations[]
  notifications   Notifications[]

  @@schema("users")
}

model Roles {
  id          String @id @default(uuid())
  name        String
  description String

  users User[]

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  @@schema("auth")
}

model AcademicProfile {
  id                   String @id @default(uuid())
  user_id              String
  academicLevel        String @map("academic_level")
  learningStyle        String @map("learning_style")
  preferredStudyTime   String @map("preferred_study_time")
  weeklyStudyGoalHours Int    @map("weekly_study_goal_hours")
  mainDifficulties     String @map("main_difficulties")

  user User @relation(fields: [user_id], references: [id])

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  @@schema("academic_profile")
}

model Subject {
  id          String  @id @default(uuid())
  name        String
  description String
  level       String
  isActive    Boolean

  subject  UserSubject[]
  quizzies Quizzies[]

  createdAt       DateTime @default(now())
  updateAt        DateTime @updatedAt
  grades          Grades[]
  studySessions   StudySessions[]
  resouces        Resouces[]
  recommendations Recommendations[]

  @@schema("subject")
}

model UserSubject {
  id              String @id @default(uuid())
  userId          String @map("user_id")
  subjectId       String @map("subject_id")
  currentAverage  String @map("current_average")
  difficultyLevel String @map("difficulty_level")
  status          String

  user    User    @relation(fields: [userId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@schema("users")
}

model Quizzies {
  id               String  @id @default(uuid())
  subjectId        String  @map("subject_id")
  title            String
  description      String
  difficulty       String
  timeLimitMinutes Int     @map("time_limit_minutes")
  isActive         Boolean

  createBy String   @map("create_by")
  createAt DateTime @map("create_at")

  subject Subject @relation(fields: [subjectId], references: [id])
  user    User    @relation(fields: [createBy], references: [id])

  quizziesAttempts QuizAttempts[]
  question          Questions[]

  @@schema("quizz")
}

model QuizAttempts {
  id             String  @id @default(uuid())
  quizId         String  @map("quizz_id")
  userId         String  @map("user_id")
  score          Decimal
  totalQuestion  Int     @map("total_questions")
  correctAnswers Int     @map("correct_answers")

  startedAt  DateTime @map("started_at")
  finishedAt DateTime @map("finished_at")

  quizzies      Quizzies        @relation(fields: [quizId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  studenAnswers StudenAnswers[]

  @@schema("quizz")
}

model Questions {
  id           String @id @default(uuid())
  quizId       String @map("quizz_id")
  questionText String @map("question_text")
  questionType String @map("question_type")
  points       Int
  topic        String
  difficulty   String

  quizzies        Quizzies          @relation(fields: [quizId], references: [id])
  questionOptions QuestionOptions[]
  studenAnswers   StudenAnswers[]

  @@schema("quizz")
}

model QuestionOptions {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  optionText String  @map("option_text")
  isCorrect  Boolean @map("is_correct")

  question      Questions       @relation(fields: [questionId], references: [id])
  studenAnswers StudenAnswers[]

  @@schema("quizz")
}

model StudenAnswers {
  id               String  @id @default(uuid())
  quizAttemptId    String  @map("quiz_attempt_id")
  questionId       String  @map("question_id")
  selectedOptionId String  @map("selected_option_id")
  isCorrect        Boolean @map("is_correct")

  quizzAttempts   QuizAttempts    @relation(fields: [quizAttemptId], references: [id])
  question        Questions       @relation(fields: [questionId], references: [id])
  questionOptions QuestionOptions @relation(fields: [selectedOptionId], references: [id])

  @@schema("quizz")
}

model Grades {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  subjectId   String   @map("subject_id")
  gradeValue  Decimal  @map("grade_value")
  gradeType   String   @map("grade_type")
  description String
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@schema("academic_profile")
}

model StudySessions {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  subjectId          String   @map("subject_id")
  startedAt          DateTime @map("started_at")
  endedAt            DateTime @map("ended_at")
  durationMinutes    Int      @map("duration_minutes")
  notes              String
  studyMethod        String   @map("study_method")
  productivityRating Int      @map("productivity_rating")

  user    User    @relation(fields: [userId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@schema("academic_profile")
}

model Resouces {
  id           String   @id @default(uuid())
  subjectId    String   @map("subject_id")
  title        String
  description  String
  resourceType String   @map("resource_type")
  url          String
  difficulty   String
  topic        String
  createdBy    String   @map("created_by")
  isActive     Boolean  @map("is_active")
  createdAt    DateTime @map("created_at")

  subject         Subject           @relation(fields: [subjectId], references: [id])
  recommendations Recommendations[]

  @@schema("subject")
}

model Recommendations {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  subjectId   String   @map("subject_id")
  resourceId  String   @map("resource_id")
  type        String
  title       String
  description String
  reason      String
  priority    String
  status      String
  createdAt   DateTime @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  subject  Subject  @relation(fields: [subjectId], references: [id])
  resource Resouces @relation(fields: [resourceId], references: [id])

  @@schema("subject")
}

model Notifications {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  message    String
  type       String
  isRead     Boolean  @map("is_read")
  scheduleAt DateTime @map("schedule_at")
  createdAt  DateTime @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@schema("users")
}